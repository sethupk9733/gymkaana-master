# Marketplace Web App Environment Configuration
# ═════════════════════════════════════════════════════════════════

# ─── API Configuration ────────────────────────────────────────
# Backend API endpoints
VITE_API_URL=http://localhost:5000/api

# Frontend URLs (for redirects and links)
VITE_MARKETPLACE_URL=http://localhost:5176
VITE_OWNER_URL=http://localhost:5173
VITE_ADMIN_URL=http://localhost:5174

# ─── Cashfree Payment Gateway ─────────────────────────────────
# Official Cashfree Payments Gateway Integration
# Documentation: https://docs.cashfree.com/docs/payment-gateway-api
#
# App ID Examples:
#   Sandbox: TEST110453444cb726ad00d64258379644354011 (starts with TEST)
#   Production: APP1234567890abcdef (no TEST prefix)
#
# The SDK automatically detects sandbox/production mode based on the prefix.

VITE_CASHFREE_APP_ID=TEST110453444cb726ad00d64258379644354011

# ─── Build/Environment ───────────────────────────────────────
# Set to true when building for production
# VITE_NODE_ENV=production
